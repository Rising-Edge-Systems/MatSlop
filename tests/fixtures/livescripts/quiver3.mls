  "cells": [
    {
      "type": "code",
      "content": "% APM 5441 Winter 2025\n% 9.4 Homework, Adam Kidwell\n% Plotting vector fields defined\n% by vector functions (I made it 3D\n% compatible, but all problems are 2D)\n\nclear;\n\n% Define the point cloud\nn = 5\n[X, Y, Z] = meshgrid(1:n, 1:n, 1:n);\nP = [X(:), Y(:), Z(:)];\n\n% Calculate the vector field\nV = v_1(P);\n\n% Plot the vector field\nquiver3(P(:,1), P(:,2), P(:,3), V(:,1), V(:,2), V(:,3));\ngrid on;\nxlabel('X'); ylabel('Y'); zlabel('Z');\nview([0 90.00])\n\n% Repeat for remaining problems\n\nV = v_2(P);\n\nquiver3(P(:,1), P(:,2), P(:,3), V(:,1), V(:,2), V(:,3));\ngrid on;\nxlabel('X'); ylabel('Y'); zlabel('Z');\nview([0 90.00])\n\nV = v_3(P);\n\nquiver3(P(:,1), P(:,2), P(:,3), V(:,1), V(:,2), V(:,3));\ngrid on;\nxlabel('X'); ylabel('Y'); zlabel('Z');\nview([0 90.00])\n\nV = v_4(P);\n\nquiver3(P(:,1), P(:,2), P(:,3), V(:,1), V(:,2), V(:,3));\ngrid on;\nxlabel('X'); ylabel('Y'); zlabel('Z');\nview([0 90.00])\n",
      "output": ""
    },
    {
      "type": "code",
      "content": "function [V] = v_1(P)\r\n    % 9.4 p15\r\n\r\n    % Break the points into x, y, and z coords\r\n    x = P(:,1);\r\n    y = P(:,2);\r\n    z = P(:,3);\r\n\r\n    % Prepare the output arrays\r\n    % (u, v, and w are the x, y, and z\r\n    %  coordinates of the endpoints)\r\n    len = numel(x);\r\n    u = zeros(len,1);\r\n    v = zeros(len,1);\r\n    w = zeros(len,1);\r\n\r\n    % Calculate the vector function\r\n    % v(p) = [u, v, w]\r\n    % v = i - j\r\n    % v(p) = [1, -1, 0]\r\n    for idx = 1:len\r\n        u(idx) = 1;\r\n        v(idx) = -1;\r\n        w(idx) = 0;\r\n    end\r\n    \r\n    % Format for return\r\n    V = [u, v, w];\r\n\r\nend\r\n\r\nfunction [V] = v_2(P)\r\n    % 9.4 p17\r\n\r\n    % Break the points into x, y, and z coords\r\n    x = P(:,1);\r\n    y = P(:,2);\r\n    z = P(:,3);\r\n\r\n    % Prepare the output arrays\r\n    % (u, v, and w are the x, y, and z\r\n    %  coordinates of the endpoints)\r\n    len = numel(x);\r\n    u = zeros(len,1);\r\n    v = zeros(len,1);\r\n    w = zeros(len,1);\r\n\r\n    % Calculate the vector function\r\n    % v(p) = [u, v, w]\r\n    % v = i + jx^2\r\n    % v(p) = [1, x^2, 0]\r\n    for idx = 1:len\r\n        u(idx) = 1;\r\n        v(idx) = x(idx)^2;\r\n        w(idx) = 0;\r\n    end\r\n    \r\n    % Format for return\r\n    V = [u, v, w];\r\n\r\nend\r\n\r\nfunction [V] = v_3(P)\r\n    % 9.4 p19\r\n\r\n    % Break the points into x, y, and z coords\r\n    x = P(:,1);\r\n    y = P(:,2);\r\n    z = P(:,3);\r\n\r\n    % Prepare the output arrays\r\n    % (u, v, and w are the x, y, and z\r\n    %  coordinates of the endpoints)\r\n    len = numel(x);\r\n    u = zeros(len,1);\r\n    v = zeros(len,1);\r\n    w = zeros(len,1);\r\n\r\n    % Calculate the vector function\r\n    % v(p) = [u, v, w]\r\n    % v = yi - xj\r\n    % v(p) = [y, -x, 0]\r\n    for idx = 1:len\r\n        u(idx) = y(idx);\r\n        v(idx) = -x(idx);\r\n        w(idx) = 0;\r\n    end\r\n    \r\n    % Format for return\r\n    V = [u, v, w];\r\n\r\nend\r\n\r\nfunction [V] = v_4(P)\r\n    % 9.4 p20\r\n\r\n    % Break the points into x, y, and z coords\r\n    x = P(:,1);\r\n    y = P(:,2);\r\n    z = P(:,3);\r\n\r\n    % Prepare the output arrays\r\n    % (u, v, and w are the x, y, and z\r\n    %  coordinates of the endpoints)\r\n    len = numel(x);\r\n    u = zeros(len,1);\r\n    v = zeros(len,1);\r\n    w = zeros(len,1);\r\n\r\n    % Calculate the vector function\r\n    % v(p) = [u, v, w]\r\n    % v = (x-y)i + (x+y)j\r\n    % v(p) = [x-y, x+y, 0]\r\n    for idx = 1:len\r\n        u(idx) = x(idx)-y(idx);\r\n        v(idx) = x(idx)+y(idx);\r\n        w(idx) = 0;\r\n    end\r\n    \r\n    % Format for return\r\n    V = [u, v, w];\r\n\r\nend",
      "output": ""
    }
  ]
}